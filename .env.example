# Shared secrets (used by Docker Compose and backend via config.py)
POSTGRES_PASSWORD=strong_random_password
SECRET_KEY=64_char_random_hex_string

# LLM — set provider to "openai" or "gemini"
LLM_PROVIDER=openai
OPENAI_API_KEY=sk-...
GEMINI_API_KEY=

# Frontend auth (used by Docker Compose and frontend/.env.local)
NEXTAUTH_SECRET=32_char_random_string
